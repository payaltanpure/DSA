
class Solution {
    public int maxDistance(int[] colors) {

        int max_distance = Integer.MIN_VALUE;
        for (int i=0; i<colors.length;i++)
        {
            for (int j=i+1; j<colors.length;j++)
            {
    
                if(colors[i]!=colors[j])
                {
                   max_distance= Math.max(max_distance,j-i);
                }

            }
        
        }
        return max_distance;
    }
}